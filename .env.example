# MCP Server environment variables
# Copy to .env and fill in values

# ── Required ──────────────────────────────────────────────────────────────────

# Joern REST server URL (optional — joern_filter gracefully skips if unavailable)
JOERN_BASE_URL=http://localhost:8080

# Burp MCP server URL (optional — only needed for burp_send)
BURP_MCP_BASE_URL=http://localhost:1337

# ── Optional ──────────────────────────────────────────────────────────────────

# GitNexus binary path (default: gitnexus on PATH)
GITNEXUS_BINARY=gitnexus

# GitNexus query timeout in seconds (default: 120)
GITNEXUS_TIMEOUT=120

# Triage minimum score threshold (default: 6)
TRIAGE_THRESHOLD=6

# Maximum paths to keep after triage (default: 200)
MAX_PATHS=200

# Directory where reports/<run_id>/ are written (default: ./reports)
REPORTS_DIR=./reports
